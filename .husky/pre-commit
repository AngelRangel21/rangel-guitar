#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Iniciando verificaciones de pre-commit..."

# 1. Verificar tipos en TODA la app (sin emitir archivos)
echo "🔍 Revisando TypeScript..."
bun run type-check || exit 1

# 2. Ejecutar linter solo en los archivos modificados
echo "💅 Ejecutando Linter (biome)..."
bunx lint-staged || exit 1

# 3. Simular un build rápido (Opcional pero recomendado para apps críticas)
# echo "🏗️ Verificando integridad de la Build..."
# npm run build || exit 1

echo "✅ Todo perfecto. Creando commit..."